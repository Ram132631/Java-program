import java.util.*;
public class Main {
    public int largestAltitude(int[] gain) {
        int maxHeight = 0;
        int currHeight = 0;
        for (int g : gain) {
            currHeight += g;
            maxHeight = Math.max(maxHeight, currHeight);
        }
        return maxHeight;
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int[] gain = new int[n];
        for (int i = 0; i < n; i++) {
            gain[i] = sc.nextInt();
        }
        Main obj = new Main();
        System.out.println(obj.largestAltitude(gain));
        sc.close();
    }
}