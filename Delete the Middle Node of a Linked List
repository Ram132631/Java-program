import java.util.*;
class ListNode {
    int val;
    ListNode next;
    ListNode(int val) {
        this.val = val;
    }
}
public class Main {
    static class NodeRef {
        ListNode node;
    }
    public ListNode deleteMiddle(ListNode head) {
        if (head == null || head.next == null) {
            return null;
        }
        NodeRef ref = new NodeRef();
        ref.node = head;
        delet(ref, head);
        return ref.node;
    }
    private void delet(NodeRef head, ListNode h) {
        if (h == null || h.next == null) {
            head.node = head.node.next;
        } else {
            NodeRef nextRef = new NodeRef();
            nextRef.node = head.node.next;
            delet(nextRef, h.next.next);
            head.node.next = nextRef.node;
        }
    }
    static void printList(ListNode head) {
        while (head != null) {
            System.out.print(head.val);
            if (head.next != null) {
                System.out.print(" -> ");
            }
            head = head.next;
        }
        System.out.println();
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        ListNode head = null;
        ListNode tail = null;
        for (int i = 0; i < n; i++) {
            int val = sc.nextInt();
            ListNode node = new ListNode(val);
            if (head == null) {
                head = tail = node;
            } else {
                tail.next = node;
                tail = node;
            }
        }
        Main obj = new Main();
        head = obj.deleteMiddle(head);
        printList(head);
        sc.close();
    }
}